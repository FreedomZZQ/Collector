// ui/main.slint — Collector v3
// Photo picker · Editable custom fields

import { ScrollView } from "std-widgets.slint";

// ─── Data Structures ─────────────────────────────────────────────────────────

export struct CollectionData {
    id: string,
    name: string,
    icon: string,
    item-count: int,
}

export struct ItemData {
    id: string,
    name: string,
    short-desc: string,
    has-photo: bool,          // true when a photo has been assigned
    thumbnail: image,         // loaded and passed in by Rust
    collection-id: string,
}

export struct FieldData {
    id: string,       // uuid so Rust can identify which field to delete/edit
    label: string,
    value: string,
}

// ─── Theme Global ─────────────────────────────────────────────────────────────

export global Theme {
    in-out property <bool>  dark-mode:     true;
    in-out property <color> bg-base:       #0f1117;
    in-out property <color> bg-panel:      #161b24;
    in-out property <color> bg-surface:    #1e2535;
    in-out property <color> bg-elevated:   #252d40;
    in-out property <color> bg-card:       #1a2130;
    in-out property <color> bg-card-hover: #212a3e;
    in-out property <color> bg-selected:   #1d3557;
    in-out property <color> bg-input:      #0f1117;
    in-out property <color> accent:        #4f8ef7;
    in-out property <color> accent-dim:    #2a4f96;
    in-out property <color> accent-glow:   #4f8ef730;
    in-out property <color> accent-text:   #7eb3ff;
    in-out property <color> text-primary:  #e8edf5;
    in-out property <color> text-secondary:#8896b0;
    in-out property <color> text-muted:    #4a5568;
    in-out property <color> border:        #252d40;
    in-out property <color> border-accent: #4f8ef750;
    in-out property <color> danger-bg:     #3d1515;
    in-out property <color> danger-text:   #f87171;
}

// ─── Drag Handle ──────────────────────────────────────────────────────────────

component DragHandle {
    callback drag(length);
    width: 6px;

    drag-touch := TouchArea {
        width: 6px;
        mouse-cursor: col-resize;
        property <length> start-x;
        pointer-event(e) => {
            if e.button == PointerEventButton.left && e.kind == PointerEventKind.down {
                start-x = self.mouse-x;
            }
        }
        moved => {
            if self.pressed {
                root.drag(self.mouse-x - self.start-x);
                self.start-x = self.mouse-x;
            }
        }
    }

    Rectangle {
        width: 2px; x: 2px; height: parent.height;
        background: drag-touch.has-hover || drag-touch.pressed ? Theme.accent : Theme.border;
        animate background { duration: 100ms; }
    }
}

// ─── Section Label ────────────────────────────────────────────────────────────

component SectionLabel {
    in property <string> text;
    height: 22px;
    Text {
        text: root.text; font-size: 11px; letter-spacing: 1.5px;
        color: Theme.text-muted; font-weight: 600; vertical-alignment: center;
    }
}

// ─── Icon Button ──────────────────────────────────────────────────────────────

component IconBtn {
    in property <string> label;
    in property <bool>   danger: false;
    in property <bool>   active: false;
    in property <length> btn-width: 28px;
    callback clicked;

    width: btn-width; height: 28px;
    t := TouchArea { clicked => { root.clicked(); } }

    Rectangle {
        border-radius: 6px;
        background: root.active ? Theme.accent
                  : (t.has-hover ? (root.danger ? Theme.danger-bg : Theme.bg-elevated) : transparent);
        animate background { duration: 120ms; }
        Text {
            text: root.label; font-size: 13px;
            color: root.active ? #fff
                 : (t.has-hover ? (root.danger ? Theme.danger-text : Theme.text-primary)
                                : Theme.text-secondary);
            horizontal-alignment: center; vertical-alignment: center;
            animate color { duration: 120ms; }
        }
    }
}

// ─── Color Swatch ─────────────────────────────────────────────────────────────

component ColorSwatch {
    in property <color> swatch-color;
    in property <bool>  selected;
    callback clicked;

    width: 28px; height: 28px;
    t := TouchArea { clicked => { root.clicked(); } }

    Rectangle {
        border-radius: 6px; background: root.swatch-color;
        border-width: root.selected ? 2px : (t.has-hover ? 1px : 0px);
        border-color: root.selected ? Theme.text-primary : #ffffff60;
        animate border-width { duration: 100ms; }
        if root.selected: Text {
            text: "✓"; font-size: 12px; font-weight: 700; color: #fff;
            horizontal-alignment: center; vertical-alignment: center;
        }
    }
}

// ─── Inline Field ─────────────────────────────────────────────────────────────

component InlineField {
    in property <string>     field-label;
    in-out property <string> val;
    in property <bool>       editing;
    in property <bool>       multiline: false;
    in property <length>     field-height: 34px;
    callback changed(string);

    VerticalLayout {
        spacing: 3px;
        SectionLabel { text: root.field-label; }
        Rectangle {
            height: root.field-height; border-radius: 6px;
            background: root.editing ? Theme.bg-input : Theme.bg-surface;
            border-width: 1px;
            border-color: root.editing ? Theme.accent-dim : Theme.border;
            animate background { duration: 130ms; }

            if root.editing: TextInput {
                text <=> root.val; font-size: 15px; color: Theme.text-primary;
                x: 10px; y: 8px; width: parent.width - 20px; height: parent.height - 16px;
                wrap: root.multiline ? word-wrap : no-wrap;
                edited => { root.changed(self.text); }
            }
            if !root.editing: Text {
                text: root.val == "" ? "—" : root.val; font-size: 15px;
                color: root.val == "" ? Theme.text-muted : Theme.text-primary;
                overflow: elide; vertical-alignment: center; x: 10px; width: parent.width - 20px;
            }
        }
    }
}

// ─── Collection Row ───────────────────────────────────────────────────────────

component CollectionRow {
    in property <CollectionData> data;
    in property <bool>           selected;
    callback clicked;

    height: 52px;
    t := TouchArea { clicked => { root.clicked(); } }

    Rectangle {
        border-radius: 8px;
        background: root.selected ? Theme.bg-selected : (t.has-hover ? Theme.bg-surface : transparent);
        border-width: root.selected ? 1px : 0px;
        border-color: Theme.border-accent;
        animate background { duration: 140ms; }

        if root.selected: Rectangle {
            x: 0; y: 10px; width: 3px; height: parent.height - 20px;
            border-radius: 2px; background: Theme.accent;
        }

        HorizontalLayout {
            padding-left: 14px; padding-right: 10px; spacing: 10px; alignment: center;

            Rectangle {
                width: 30px; height: 30px; border-radius: 8px;
                background: root.selected ? Theme.accent-dim : Theme.bg-elevated;
                animate background { duration: 140ms; }
                Text { text: root.data.icon; font-size: 15px; horizontal-alignment: center; vertical-alignment: center; }
            }

            VerticalLayout {
                alignment: center; spacing: 2px;
                Text {
                    text: root.data.name; font-size: 15px; overflow: elide;
                    font-weight: root.selected ? 600 : 400;
                    color: root.selected ? Theme.text-primary : Theme.text-secondary;
                }
                Text { text: root.data.item-count + " items"; font-size: 12px; color: Theme.text-muted; }
            }

            if root.selected: Rectangle {
                width: 22px; height: 16px; border-radius: 8px; background: Theme.accent;
                Text {
                    text: root.data.item-count; font-size: 9px; font-weight: 700;
                    color: #fff; horizontal-alignment: center; vertical-alignment: center;
                }
            }
        }
    }
}

// ─── Item Card ────────────────────────────────────────────────────────────────

component ItemCard {
    in property <ItemData> data;
    in property <bool>     selected;
    callback clicked;

    height: 78px;
    t := TouchArea { clicked => { root.clicked(); } }

    Rectangle {
        border-radius: 10px;
        background: root.selected ? Theme.bg-selected : (t.has-hover ? Theme.bg-card-hover : Theme.bg-card);
        border-width: 1px;
        border-color: root.selected ? Theme.border-accent : Theme.border;
        animate background { duration: 140ms; }

        HorizontalLayout {
            padding: 10px; spacing: 11px; alignment: center;

            // Thumbnail
            Rectangle {
                width: 54px; height: 54px; border-radius: 8px;
                background: Theme.bg-elevated;

                if !root.data.has-photo: Text {
                    text: "📷"; font-size: 22px;
                    horizontal-alignment: center; vertical-alignment: center;
                    color: Theme.text-muted;
                }
                if root.data.has-photo: Image {
                    source: root.data.thumbnail;
                    width: 54px; height: 54px;
                    image-fit: cover;
                }
            }

            VerticalLayout {
                alignment: center; spacing: 4px;
                Text {
                    text: root.data.name; font-size: 15px; font-weight: 600; overflow: elide;
                    color: root.selected ? Theme.text-primary : Theme.text-secondary;
                }
                Text { text: root.data.short-desc; font-size: 13px; color: Theme.text-muted; overflow: elide; wrap: no-wrap; }
            }
        }
    }
}

// ─── Settings Panel ───────────────────────────────────────────────────────────

component SettingsPanel {
    callback close();
    callback toggle-dark-mode();
    callback set-accent(color);
    callback export-data();
    callback import-data();

    property <[color]> accents: [
        #4f8ef7, #7c5cbf, #2ecc71, #e67e22,
        #e74c3c, #1abc9c, #e91e8c, #f0c040,
    ];

    Rectangle { background: Theme.bg-base; opacity: 0.55; width: parent.width; height: parent.height; }

    Rectangle {
        x: (parent.width - 380px) / 2;
        y: (parent.height - 440px) / 2;
        width: 380px; height: 440px;
        border-radius: 14px; background: Theme.bg-panel;
        border-width: 1px; border-color: Theme.border;
        drop-shadow-blur: 32px; drop-shadow-color: #00000060; drop-shadow-offset-y: 8px;

        VerticalLayout {
            padding: 24px; spacing: 0px;

            HorizontalLayout {
                alignment: space-between; height: 36px;
                Text { text: "Settings"; font-size: 16px; font-weight: 700; color: Theme.text-primary; vertical-alignment: center; }
                IconBtn { label: "✕"; clicked => { root.close(); } }
            }

            Rectangle { height: 20px; }
            SectionLabel { text: "APPEARANCE"; }
            Rectangle { height: 10px; }

            HorizontalLayout {
                alignment: space-between; height: 40px;
                Text { text: Theme.dark-mode ? "Dark mode" : "Light mode"; font-size: 13px; color: Theme.text-secondary; vertical-alignment: center; }
                toggle-t := TouchArea {
                    width: 48px; height: 26px;
                    clicked => { root.toggle-dark-mode(); }
                    Rectangle {
                        border-radius: 13px;
                        background: Theme.dark-mode ? Theme.accent : Theme.bg-elevated;
                        border-width: 1px; border-color: Theme.border;
                        animate background { duration: 200ms; }
                        Rectangle {
                            width: 18px; height: 18px; border-radius: 9px; background: #fff;
                            x: Theme.dark-mode ? 26px : 4px; y: 3px;
                            animate x { duration: 200ms; easing: ease-in-out; }
                        }
                    }
                }
            }

            Rectangle { height: 6px; }

            HorizontalLayout {
                alignment: space-between; height: 40px;
                Text { text: "Accent colour"; font-size: 13px; color: Theme.text-secondary; vertical-alignment: center; }
                HorizontalLayout {
                    spacing: 5px; alignment: center;
                    for c in root.accents: ColorSwatch {
                        swatch-color: c; selected: Theme.accent == c;
                        clicked => { root.set-accent(c); }
                    }
                }
            }

            Rectangle { height: 20px; }
            Rectangle { height: 1px; background: Theme.border; }
            Rectangle { height: 20px; }
            SectionLabel { text: "DATA"; }
            Rectangle { height: 12px; }

            export-t := TouchArea {
                height: 42px;
                clicked => { root.export-data(); }
                Rectangle {
                    border-radius: 8px;
                    background: export-t.has-hover ? Theme.bg-elevated : Theme.bg-surface;
                    border-width: 1px; border-color: Theme.border;
                    animate background { duration: 120ms; }
                    HorizontalLayout {
                        padding-left: 14px; spacing: 10px; alignment: center;
                        Text { text: "⬆"; font-size: 16px; color: Theme.accent; vertical-alignment: center; }
                        VerticalLayout {
                            alignment: center;
                            Text { text: "Export collection data"; font-size: 13px; color: Theme.text-primary; }
                            Text { text: "Save as JSON backup"; font-size: 11px; color: Theme.text-muted; }
                        }
                    }
                }
            }

            Rectangle { height: 8px; }

            import-t := TouchArea {
                height: 42px;
                clicked => { root.import-data(); }
                Rectangle {
                    border-radius: 8px;
                    background: import-t.has-hover ? Theme.bg-elevated : Theme.bg-surface;
                    border-width: 1px; border-color: Theme.border;
                    animate background { duration: 120ms; }
                    HorizontalLayout {
                        padding-left: 14px; spacing: 10px; alignment: center;
                        Text { text: "⬇"; font-size: 16px; color: Theme.accent; vertical-alignment: center; }
                        VerticalLayout {
                            alignment: center;
                            Text { text: "Import collection data"; font-size: 13px; color: Theme.text-primary; }
                            Text { text: "Merge from JSON file"; font-size: 11px; color: Theme.text-muted; }
                        }
                    }
                }
            }

            Rectangle { height: 14px; }
        }
    }
}

// ─── Root Window ──────────────────────────────────────────────────────────────

export component AppWindow inherits Window {
    title: "Collector";
    min-width: 780px; min-height: 520px;
    preferred-width: 1200px; preferred-height: 760px;
    background: Theme.bg-base;

    in-out property <length> left-width: 220px;
    in-out property <length> mid-width:  268px;

    // App state
    in-out property <[CollectionData]> collections: [];
    in-out property <[ItemData]>       items: [];
    in-out property <[FieldData]>      detail-fields: [];
    in-out property <int>    selected-collection: -1;
    in-out property <int>    selected-item: -1;
    in-out property <string> detail-name: "";
    in-out property <string> detail-desc: "";
    in-out property <string> detail-notes: "";
    in-out property <string> detail-acquired: "";
    in-out property <string> detail-condition: "";
    in-out property <string> detail-value: "";
    in-out property <string> detail-tags: "";
    in-out property <bool>   detail-has-photo: false;
    in-out property <image>  detail-photo;         // loaded by Rust
    in-out property <bool>   is-editing: false;
    in-out property <bool>   show-settings: false;
    in-out property <string> status-message: "";

    // Callbacks
    callback select-collection(int);
    callback select-item(int);
    callback new-collection();
    callback delete-collection(int);
    callback new-item();
    callback delete-item(int);
    callback toggle-edit();
    callback pick-photo();
    callback field-changed(string, string);
    callback resize-left(length);
    callback resize-mid(length);
    callback toggle-dark-mode();
    callback set-accent(color);
    callback export-data();
    callback import-data();
    // Custom fields
    callback add-custom-field();
    callback delete-custom-field(string);           // field id
    callback custom-field-label-changed(string, string);  // (field-id, new-label)
    callback custom-field-value-changed(string, string);  // (field-id, new-value)

    HorizontalLayout {
        spacing: 0px;

        // ══ LEFT PANEL ════════════════════════════════════════════════════════
        Rectangle {
            width: root.left-width;
            background: Theme.bg-panel;

            VerticalLayout {
                padding: 14px; padding-top: 18px; spacing: 0px;

                HorizontalLayout {
                    alignment: space-between; height: 38px;
                    Text { text: "Collections"; font-size: 10px; letter-spacing: 1.6px; font-weight: 700; color: Theme.text-muted; vertical-alignment: center; }
                    HorizontalLayout {
                        spacing: 2px; alignment: center;
                        IconBtn { label: "⚙"; active: root.show-settings; clicked => { root.show-settings = !root.show-settings; } }
                        IconBtn { label: "+"; clicked => { root.new-collection(); } }
                    }
                }

                Rectangle { height: 8px; }

                ScrollView {
                    vertical-stretch: 1;
                    VerticalLayout {
                        spacing: 2px; padding-right: 4px;
                        for coll[i] in root.collections: CollectionRow {
                            data: coll; selected: root.selected-collection == i;
                            clicked => { root.select-collection(i); }
                        }
                        if root.collections.length == 0: Rectangle {
                            height: 140px;
                            VerticalLayout {
                                alignment: center; spacing: 6px;
                                Text { text: "🗂"; font-size: 40px; horizontal-alignment: center; color: Theme.text-muted; }
                                Text { text: "Press + to create\na collection"; font-size: 11px; color: Theme.text-muted; horizontal-alignment: center; }
                            }
                        }
                    }
                }

                if root.selected-collection >= 0: del-coll-t := TouchArea {
                    height: 36px;
                    clicked => { root.delete-collection(root.selected-collection); }
                    Rectangle {
                        border-radius: 7px; border-width: 1px; border-color: #3d1515; background: transparent;
                        HorizontalLayout {
                            alignment: center; spacing: 6px;
                            Text { text: "🗑"; font-size: 12px; vertical-alignment: center; color: Theme.danger-text; }
                            Text {
                                text: "Delete collection"; font-size: 11px; vertical-alignment: center;
                                color: del-coll-t.has-hover ? Theme.danger-text : #9b3b3b;
                                animate color { duration: 120ms; }
                            }
                        }
                    }
                }
            }
        }

        DragHandle {
            drag(delta) => {
                root.left-width = max(140px, min(360px, root.left-width + delta));
                root.resize-left(root.left-width);
            }
        }

        // ══ MIDDLE PANEL ══════════════════════════════════════════════════════
        Rectangle {
            width: root.mid-width;
            background: Theme.bg-base;

            VerticalLayout {
                padding: 14px; padding-top: 18px; spacing: 0px;

                HorizontalLayout {
                    alignment: space-between; height: 38px;
                    Text {
                        text: root.selected-collection >= 0
                            ? root.collections[root.selected-collection].name
                            : "Items";
                        font-size: 15px; font-weight: 700; color: Theme.text-primary;
                        vertical-alignment: center; overflow: elide;
                    }
                    if root.selected-collection >= 0: IconBtn { label: "+"; clicked => { root.new-item(); } }
                }

                Rectangle { height: 10px; }

                if root.selected-collection < 0: Rectangle {
                    vertical-stretch: 1;
                    VerticalLayout {
                        alignment: center; spacing: 8px;
                        Text { text: "←"; font-size: 40px; horizontal-alignment: center; color: Theme.text-muted; }
                        Text { text: "Select a collection"; font-size: 13px; color: Theme.text-muted; horizontal-alignment: center; }
                    }
                }

                if root.selected-collection >= 0: ScrollView {
                    vertical-stretch: 1;
                    VerticalLayout {
                        spacing: 5px; padding-right: 4px;
                        for item[i] in root.items: ItemCard {
                            data: item; selected: root.selected-item == i;
                            clicked => { root.select-item(i); }
                        }
                        if root.items.length == 0: Rectangle {
                            height: 140px;
                            VerticalLayout {
                                alignment: center; spacing: 6px;
                                Text { text: "📦"; font-size: 40px; horizontal-alignment: center; color: Theme.text-muted; }
                                Text { text: "Press + to add an item"; font-size: 12px; color: Theme.text-muted; horizontal-alignment: center; }
                            }
                        }
                    }
                }
            }
        }

        DragHandle {
            drag(delta) => {
                root.mid-width = max(180px, min(460px, root.mid-width + delta));
                root.resize-mid(root.mid-width);
            }
        }

        // ══ RIGHT PANEL — Detail ══════════════════════════════════════════════
        Rectangle {
            horizontal-stretch: 1;
            background: Theme.bg-panel;

            if root.selected-item < 0: Rectangle {
                VerticalLayout {
                    alignment: center; spacing: 10px;
                    Text { text: "🔍"; font-size: 40px; horizontal-alignment: center; color: Theme.text-muted; }
                    Text { text: "Select an item to view its details"; font-size: 13px; color: Theme.text-muted; horizontal-alignment: center; }
                }
            }

            if root.selected-item >= 0: VerticalLayout {
                padding: 22px; spacing: 0px;

                // Top bar
                HorizontalLayout {
                    alignment: space-between; height: 42px;
                    Text {
                        text: root.detail-name == "" ? "New Item" : root.detail-name;
                        font-size: 17px; font-weight: 700; color: Theme.text-primary;
                        vertical-alignment: center; overflow: elide;
                    }
                    HorizontalLayout {
                        spacing: 5px; alignment: center;
                        save-t := TouchArea {
                            width: 82px; height: 28px;
                            clicked => { root.toggle-edit(); }
                            Rectangle {
                                border-radius: 7px;
                                background: root.is-editing ? Theme.accent : Theme.bg-elevated;
                                border-width: 1px;
                                border-color: root.is-editing ? Theme.accent : Theme.border;
                                animate background { duration: 140ms; }
                                Text {
                                    text: root.is-editing ? "💾  Save" : "✏  Edit";
                                    font-size: 12px; font-weight: 600;
                                    color: root.is-editing ? #fff : Theme.text-secondary;
                                    horizontal-alignment: center; vertical-alignment: center;
                                }
                            }
                        }
                        IconBtn { label: "🗑"; danger: true; clicked => { root.delete-item(root.selected-item); } }
                    }
                }

                Rectangle { height: 14px; }

                // Photo + name/desc row
                HorizontalLayout {
                    spacing: 18px; height: 152px;

                    // Photo box
                    photo-box := Rectangle {
                        width: 140px; height: 140px; border-radius: 11px;
                        background: Theme.bg-surface; border-width: 1px; border-color: Theme.border;
                        clip: true;

                        // Placeholder when no photo
                        if !root.detail-has-photo: VerticalLayout {
                            alignment: center; spacing: 5px;
                            Text { text: "📷"; font-size: 32px; horizontal-alignment: center; color: Theme.text-muted; }
                            if root.is-editing: Text { text: "Click to add photo"; font-size: 9px; color: Theme.text-muted; horizontal-alignment: center; }
                        }

                        // Actual photo
                        if root.detail-has-photo: Image {
                            source: root.detail-photo;
                            width: 140px; height: 140px;
                            image-fit: cover;
                        }

                        // Overlay button in edit mode
                        if root.is-editing: photo-touch := TouchArea {
                            clicked => { root.pick-photo(); }
                            Rectangle {
                                border-radius: 11px; background: #00000055;
                                visible: photo-touch.has-hover;
                                Text {
                                    text: root.detail-has-photo ? "Change" : "Add photo";
                                    font-size: 12px; color: #fff; font-weight: 600;
                                    horizontal-alignment: center; vertical-alignment: center;
                                }
                            }
                        }
                    }

                    // Name + description
                    VerticalLayout {
                        alignment: start; spacing: 10px;

                        VerticalLayout {
                            spacing: 3px;
                            SectionLabel { text: "NAME"; }
                            Rectangle {
                                height: 34px; border-radius: 6px;
                                background: root.is-editing ? Theme.bg-input : transparent;
                                border-width: root.is-editing ? 1px : 0px;
                                border-color: Theme.accent-dim;
                                animate background { duration: 130ms; }
                                if root.is-editing: TextInput {
                                    text <=> root.detail-name; font-size: 16px; font-weight: 600;
                                    color: Theme.text-primary; x: 10px; y: 8px; width: parent.width - 20px;
                                    edited => { root.field-changed("name", self.text); }
                                }
                                if !root.is-editing: Text {
                                    text: root.detail-name; font-size: 16px; font-weight: 600;
                                    color: Theme.text-primary; vertical-alignment: center; x: 2px;
                                }
                            }
                        }

                        VerticalLayout {
                            spacing: 3px;
                            SectionLabel { text: "SHORT DESCRIPTION"; }
                            Rectangle {
                                height: 58px; border-radius: 6px;
                                background: root.is-editing ? Theme.bg-input : transparent;
                                border-width: root.is-editing ? 1px : 0px;
                                border-color: Theme.accent-dim;
                                animate background { duration: 130ms; }
                                if root.is-editing: TextInput {
                                    text <=> root.detail-desc; font-size: 14px; color: Theme.text-secondary;
                                    x: 10px; y: 8px; width: parent.width - 20px; height: parent.height - 16px;
                                    wrap: word-wrap;
                                    edited => { root.field-changed("desc", self.text); }
                                }
                                if !root.is-editing: Text {
                                    text: root.detail-desc == "" ? "No description" : root.detail-desc;
                                    font-size: 14px;
                                    color: root.detail-desc == "" ? Theme.text-muted : Theme.text-secondary;
                                    wrap: word-wrap; x: 2px; width: parent.width - 4px;
                                }
                            }
                        }
                    }
                }

                Rectangle { height: 16px; }
                Rectangle { height: 1px; background: Theme.border; }
                Rectangle { height: 14px; }

                // Details header + Add Field button
                HorizontalLayout {
                    alignment: space-between; height: 22px;
                    SectionLabel { text: "DETAILS"; }
                    if root.is-editing: IconBtn {
                        label: "+ Field"; btn-width: 56px;
                        clicked => { root.add-custom-field(); }
                    }
                }

                Rectangle { height: 8px; }

                // Scrollable fields
                ScrollView {
                    vertical-stretch: 1;
                    VerticalLayout {
                        spacing: 10px;

                        // Standard fields row
                        HorizontalLayout {
                            spacing: 12px; height: 58px;
                            InlineField { field-label: "ACQUIRED";     val <=> root.detail-acquired;  editing: root.is-editing; changed(v) => { root.field-changed("acquired",  v); } }
                            InlineField { field-label: "CONDITION";    val <=> root.detail-condition; editing: root.is-editing; changed(v) => { root.field-changed("condition", v); } }
                            InlineField { field-label: "VALUE / PRICE"; val <=> root.detail-value;   editing: root.is-editing; changed(v) => { root.field-changed("value",     v); } }
                        }

                        InlineField { field-label: "TAGS"; val <=> root.detail-tags; editing: root.is-editing; changed(v) => { root.field-changed("tags", v); } }

                        InlineField {
                            field-label: "NOTES"; val <=> root.detail-notes;
                            editing: root.is-editing; multiline: true; field-height: 110px;
                            changed(v) => { root.field-changed("notes", v); }
                        }

                        // Custom fields — editable label + value when in edit mode
                        for f in root.detail-fields: VerticalLayout {
                            height: 68px;
                            spacing: 3px;

                            // Label row
                            HorizontalLayout {
                                height: 22px; spacing: 4px; alignment: space-between;

                                if root.is-editing: TextInput {
                                    text: f.label;
                                    font-size: 11px; letter-spacing: 1.5px; font-weight: 600;
                                    color: Theme.text-muted;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                    edited => { root.custom-field-label-changed(f.id, self.text); }
                                }
                                if !root.is-editing: Text {
                                    text: f.label; font-size: 11px; letter-spacing: 1.5px;
                                    font-weight: 600; color: Theme.text-muted;
                                    horizontal-stretch: 1; vertical-alignment: center;
                                }

                                if root.is-editing: IconBtn {
                                    label: "✕"; danger: true; btn-width: 22px;
                                    clicked => { root.delete-custom-field(f.id); }
                                }
                            }

                            // Value
                            Rectangle {
                                height: 34px; border-radius: 6px;
                                background: root.is-editing ? Theme.bg-input : Theme.bg-surface;
                                border-width: 1px;
                                border-color: root.is-editing ? Theme.accent-dim : Theme.border;
                                animate background { duration: 130ms; }

                                if root.is-editing: TextInput {
                                    text: f.value; font-size: 15px; color: Theme.text-primary;
                                    x: 10px; y: 8px;
                                    height: parent.height - 16px;
                                    horizontal-stretch: 1;
                                    edited => { root.custom-field-value-changed(f.id, self.text); }
                                }
                                if !root.is-editing: Text {
                                    text: f.value == "" ? "—" : f.value; font-size: 15px;
                                    color: f.value == "" ? Theme.text-muted : Theme.text-primary;
                                    vertical-alignment: center; x: 10px;
                                }
                            }
                        }

                        Rectangle { height: 16px; }
                    }
                }

                // Status bar
                if root.status-message != "": Rectangle {
                    height: 28px; border-radius: 6px; background: Theme.bg-surface;
                    Text { text: root.status-message; font-size: 11px; color: Theme.accent-text; x: 10px; vertical-alignment: center; }
                }
            }
        }
    }

    // Settings overlay
    if root.show-settings: SettingsPanel {
        width: root.width; height: root.height;
        close => { root.show-settings = false; }
        toggle-dark-mode => { root.toggle-dark-mode(); }
        set-accent(c) => { root.set-accent(c); }
        export-data => { root.export-data(); root.show-settings = false; }
        import-data => { root.import-data(); root.show-settings = false; }
    }
}
